// c++ priority queue

#include <bits/stdc++.h>
using namespace std;

int main()
{
    priority_queue<int> pq; // max heap
    priority_queue<int, vector<int>, greater<int>> dq; // min heap
    pq.push(4);
    pq.push(8);

    while (!pq.empty())
    {
        int top = pq.top();
        cout << top << " ";
        pq.pop();
    }
    cout<<endl;

    
    dq.push(4);
    dq.push(8);

       while (!dq.empty())
    {
        int top = dq.top();
        cout << top << " ";
        dq.pop();
    }
    return 0;
}
