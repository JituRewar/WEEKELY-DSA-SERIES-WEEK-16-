# ✅ C++ Solution

## solution.cpp

```cpp
#include <bits/stdc++.h>
using namespace std;

// Function to find MST cost using Prim's Algorithm
int primsMST(int V, vector<vector<pair<int, int>>> adj)
{
    vector<bool> mstset(V, false);

    // Min Heap -> {weight, vertex}
    priority_queue<pair<int, int>, vector<pair<int, int>>, greater<pair<int, int>>> pq;

    pq.push({0, 0});

    int minWT = 0;

    while (!pq.empty())
    {
        int u = pq.top().second;
        int wt = pq.top().first;
        pq.pop();

        if (!mstset[u])
        {
            mstset[u] = true;
            minWT += wt;

            for (int i = 0; i < adj[u].size(); i++)
            {
                int v = adj[u][i].first;
                int w = adj[u][i].second;

                if (!mstset[v])
                {
                    pq.push({w, v});
                }
            }
        }
    }

    return minWT;
}

int main()
{
    int V = 5;

    vector<vector<pair<int, int>>> adj(V);

    // Undirected Weighted Graph

    adj[0].push_back({1, 10});
    adj[1].push_back({0, 10});

    adj[0].push_back({3, 30});
    adj[3].push_back({0, 30});

    adj[0].push_back({2, 15});
    adj[2].push_back({0, 15});

    adj[1].push_back({3, 40});
    adj[3].push_back({1, 40});

    adj[2].push_back({3, 50});
    adj[3].push_back({2, 50});

    cout << "Cost of MST " << primsMST(V, adj) << endl;

    return 0;
}
```

